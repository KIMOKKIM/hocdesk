# App
NEXT_PUBLIC_BASE_PATH="/Jinwoong"
APP_URL="http://localhost:3000/Jinwoong"

# Database
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Search (production: kakao)
TARGET_SEARCH_PROVIDER="kakao"
KAKAO_REST_API_KEY=""
ALLOW_DEMO_PROVIDER_IN_PRODUCTION="false"

# AI
AI_PROVIDER="rules"
OPENAI_API_KEY=""

# Email
EMAIL_PROVIDER="console"
DEFAULT_SENDER_NAME=""
DEFAULT_SENDER_EMAIL=""
DEFAULT_SENDER_PHONE=""

# Security — ID/PW admin login
ADMIN_USERNAME=""
ADMIN_PASSWORD=""
# Optional: base64 of password (recommended when password contains `$`)
ADMIN_PASSWORD_B64=""
SESSION_SECRET=""
# Deprecated: no longer used by the login UI (optional bearer automation only)
ADMIN_ACCESS_KEY=""
CRON_SECRET=""
# Note: If ADMIN_PASSWORD contains `$`, prefer ADMIN_PASSWORD_B64 on Vercel.
#   Local .env example with escapes: ADMIN_PASSWORD="prefix\$\$suffix"

# Application (production: INCLUDE_DEMO_DATA=false)
INCLUDE_DEMO_DATA="false"
ADMIN_DISPLAY_NAME="HOCDESK"
NODE_ENV="development"
