# App
NEXT_PUBLIC_BASE_PATH="/Jinwoong"
APP_URL="http://localhost:3000/Jinwoong"

# Database
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Search
TARGET_SEARCH_PROVIDER="demo"
KAKAO_REST_API_KEY=""

# AI
AI_PROVIDER="rules"
OPENAI_API_KEY=""

# Email
EMAIL_PROVIDER="console"
DEFAULT_SENDER_NAME=""
DEFAULT_SENDER_EMAIL=""
DEFAULT_SENDER_PHONE=""

# Security — ID/PW admin login
ADMIN_USERNAME=""
ADMIN_PASSWORD=""
SESSION_SECRET=""
# Deprecated: no longer used by the login UI (optional bearer automation only)
ADMIN_ACCESS_KEY=""
CRON_SECRET=""
# Note: If ADMIN_PASSWORD contains `$`, escape each `$` as `\$` in local .env
#   Example: ADMIN_PASSWORD="prefix\$\$suffix"
#   On Vercel Environment Variables UI, enter the literal password without backslashes.

# Application
INCLUDE_DEMO_DATA="true"
NODE_ENV="development"
